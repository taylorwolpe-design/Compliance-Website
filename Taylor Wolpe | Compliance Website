mat('woff2');\n  unicode-range: U+0460-052F, U+1C80-1C8A, U+20B4, U+2DE0-2DFF, U+A640-A69F, U+FE2E-FE2F;\n}\n/* cyrillic */\n@font-face {\n  font-family: 'Unbounded';\n  font-style: normal;\n  font-weight: 700;\n  font-display: swap;\n  src: url(\"61eef07d-0134-4294-af05-b01bc501623a\") format('woff2');\n  unicode-range: U+0301, U+0400-045F, U+0490-0491, U+04B0-04B1, U+2116;\n}\n/* vietnamese */\n@font-face {\n  font-family: 'Unbounded';\n  font-style: normal;\n  font-weight: 700;\n  font-display: swap;\n  src: url(\"ee3ba37b-9699-4a57-920a-47c3234a7698\") format('woff2');\n  unicode-range: U+0102-0103, U+0110-0111, U+0128-0129, U+0168-0169, U+01A0-01A1, U+01AF-01B0, U+0300-0301, U+0303-0304, U+0308-0309, U+0323, U+0329, U+1EA0-1EF9, U+20AB;\n}\n/* latin-ext */\n@font-face {\n  font-family: 'Unbounded';\n  font-style: normal;\n  font-weight: 700;\n  font-display: swap;\n  src: url(\"41afef13-bc8c-4483-afae-21e7edac8b16\") format('woff2');\n  unicode-range: U+0100-02BA, U+02BD-02C5, U+02C7-02CC, U+02CE-02D7, U+02DD-02FF, U+0304, U+0308, U+0329, U+1D00-1DBF, U+1E00-1E9F, U+1EF2-1EFF, U+2020, U+20A0-20AB, U+20AD-20C0, U+2113, U+2C60-2C7F, U+A720-A7FF;\n}\n/* latin */\n@font-face {\n  font-family: 'Unbounded';\n  font-style: normal;\n  font-weight: 700;\n  font-display: swap;\n  src: url(\"8d48d96f-23cd-430c-bac4-6e961f9213f5\") format('woff2');\n  unicode-range: U+0000-00FF, U+0131, U+0152-0153, U+02BB-02BC, U+02C6, U+02DA, U+02DC, U+0304, U+0308, U+0329, U+2000-206F, U+20AC, U+2122, U+2191, U+2193, U+2212, U+2215, U+FEFF, U+FFFD;\n}\n<\u002Fstyle>\n<style>\n  * { box-sizing: border-box; }\n  html, body { margin: 0; background:#FBF6EE; }\n  @keyframes riseIn { from { opacity:0; transform:translateY(14px); } to { opacity:1; transform:translateY(0); } }\n<\u002Fstyle>\n<\u002Fhelmet>\n\n<div style=\"min-height:100vh; background:#FBF6EE; font-family:'Hanken Grotesk',sans-serif; color:#211C17; display:flex; flex-direction:column;\">\n\n  <!-- disclaimer -->\n  <div style=\"background:#211C17; color:#f1ead9; text-align:center; padding:8px 16px; font-family:'Space Mono',monospace; font-size:11.5px; letter-spacing:.03em; line-height:1.4;\">FICTIONAL SAMPLE · A learning-design concept by Taylor Wolpe — “Brindle Beverage Co.” is invented, not a real company.<\u002Fdiv>\n\n  <!-- module header -->\n  <div style=\"background:rgba(251,246,238,.92); backdrop-filter:blur(10px); border-bottom:1px solid #ece0cc; position:sticky; top:0; z-index:10;\">\n    <div style=\"max-width:760px; margin:0 auto; padding:14px 24px; display:flex; align-items:center; gap:16px;\">\n      <div style=\"display:flex; align-items:center; gap:9px;\">\n        <div style=\"width:30px; height:30px; border-radius:50%; background:#211C17; display:flex; align-items:center; justify-content:center; position:relative;\"><div style=\"width:0; height:0; border-left:4px solid transparent; border-right:4px solid transparent; border-bottom:11px solid #E2701A; transform:translateY(-2px) rotate(40deg);\"><\u002Fdiv><\u002Fdiv>\n        <div style=\"font-family:'Space Mono',monospace; font-size:12px; font-weight:700; color:#7A6F60; letter-spacing:.04em;\">COMPASS TRAINING<\u002Fdiv>\n      <\u002Fdiv>\n      <div style=\"flex:1; display:flex; align-items:center; gap:10px;\">\n        <div style=\"flex:1; height:7px; background:#ece0cc; border-radius:5px; overflow:hidden;\"><div style=\"width:{{ progressPct }}; height:100%; background:#E2701A; transition:width .35s;\"><\u002Fdiv><\u002Fdiv>\n        <div style=\"font-family:'Space Mono',monospace; font-size:11px; color:#a59986;\">{{ progressLabel }}<\u002Fdiv>\n      <\u002Fdiv>\n    <\u002Fdiv>\n  <\u002Fdiv>\n\n  <div style=\"flex:1; display:flex; align-items:flex-start; justify-content:center; padding:36px 24px 60px;\">\n    <div style=\"width:100%; max-width:680px;\">\n\n      <!-- ===== COVER ===== -->\n      <sc-if value=\"{{ isCover }}\" hint-placeholder-val=\"{{ true }}\">\n      <div style=\"\">\n        <div style=\"background:#211C17; border-radius:24px; padding:40px 36px; color:#FBF6EE; position:relative; overflow:hidden;\">\n          <div style=\"position:absolute; right:-50px; bottom:-50px; width:180px; height:180px; border-radius:50%; background:#E2701A; opacity:.18;\"><\u002Fdiv>\n          <div style=\"font-family:'Space Mono',monospace; font-size:12px; letter-spacing:.1em; color:#E2701A; font-weight:700;\">MODULE 02 · 4 MIN · INTERACTIVE<\u002Fdiv>\n          <div style=\"font-family:'Unbounded',sans-serif; font-size:38px; font-weight:700; line-height:1.04; margin-top:16px; letter-spacing:-.02em;\">Conflicts of Interest<\u002Fdiv>\n          <div style=\"font-size:17px; color:#c2bbb2; margin-top:14px; line-height:1.55; max-width:480px;\">No policy quotes, no legalese. Just how to spot a conflict, what to do about it, and one scenario you’ll probably face for real.<\u002Fdiv>\n          <div onclick=\"{{ start }}\" style=\"margin-top:26px; display:inline-flex; align-items:center; gap:9px; background:#E2701A; color:#fff; padding:14px 26px; border-radius:30px; font-weight:700; font-size:15px; cursor:pointer;\">Start the module →<\u002Fdiv>\n        <\u002Fdiv>\n        <div style=\"margin-top:18px; display:flex; gap:12px;\">\n          <div style=\"flex:1; background:#fff; border:1px solid #ece0cc; border-radius:16px; padding:18px;\"><div style=\"font-size:22px;\">🧐<\u002Fdiv><div style=\"font-weight:700; margin-top:8px; font-size:15px;\">Spot it<\u002Fdiv><div style=\"font-size:13px; color:#7A6F60; margin-top:3px; line-height:1.45;\">Know one when you see it.<\u002Fdiv><\u002Fdiv>\n          <div style=\"flex:1; background:#fff; border:1px solid #ece0cc; border-radius:16px; padding:18px;\"><div style=\"font-size:22px;\">🗣️<\u002Fdiv><div style=\"font-weight:700; margin-top:8px; font-size:15px;\">Say it<\u002Fdiv><div style=\"font-size:13px; color:#7A6F60; margin-top:3px; line-height:1.45;\">Disclose the easy way.<\u002Fdiv><\u002Fdiv>\n          <div style=\"flex:1; background:#fff; border:1px solid #ece0cc; border-radius:16px; padding:18px;\"><div style=\"font-size:22px;\">🤝<\u002Fdiv><div style=\"font-weight:700; margin-top:8px; font-size:15px;\">Step back<\u002Fdiv><div style=\"font-size:13px; color:#7A6F60; margin-top:3px; line-height:1.45;\">Let someone neutral call it.<\u002Fdiv><\u002Fdiv>\n        <\u002Fdiv>\n      <\u002Fdiv>\n      <\u002Fsc-if>\n\n      <!-- ===== TEACH ===== -->\n      <sc-if value=\"{{ isTeach }}\" hint-placeholder-val=\"{{ false }}\">\n      <div key=\"{{ stepKey }}\" style=\"\">\n        <div style=\"font-family:'Space Mono',monospace; font-size:12px; font-weight:700; color:#E2701A; letter-spacing:.06em;\">{{ tKicker }}<\u002Fdiv>\n        <div style=\"font-family:'Unbounded',sans-serif; font-size:30px; font-weight:700; line-height:1.08; margin-top:10px; letter-spacing:-.02em;\">{{ tTitle }}<\u002Fdiv>\n        <div style=\"font-size:18px; color:#43392f; margin-top:16px; line-height:1.6;\">{{ tBody }}<\u002Fdiv>\n        <div style=\"margin-top:22px;\">{{ tBlock }}<\u002Fdiv>\n      <\u002Fdiv>\n      <\u002Fsc-if>\n\n      <!-- ===== SCENARIO ===== -->\n      <sc-if value=\"{{ isScenario }}\" hint-placeholder-val=\"{{ false }}\">\n      <div style=\"\">\n        <div style=\"display:inline-block; background:#ece7f7; color:#6B4FB0; border-radius:20px; padding:4px 13px; font-family:'Space Mono',monospace; font-size:11px; font-weight:700;\">SCENARIO<\u002Fdiv>\n        <div style=\"font-family:'Unbounded',sans-serif; font-size:26px; font-weight:600; line-height:1.12; margin-top:14px; letter-spacing:-.01em;\">Your call.<\u002Fdiv>\n        <div style=\"background:#fff; border:1px solid #ece0cc; border-radius:18px; padding:22px; margin-top:14px; font-size:17px; line-height:1.6; color:#211C17;\">Your younger sister just launched a design studio. It’s pitching to become Brindle’s new packaging agency — and you’re one of three people on the panel that picks the winner. <strong>What do you do?<\u002Fstrong><\u002Fdiv>\n\n        <div style=\"margin-top:16px; display:flex; flex-direction:column; gap:11px;\">\n          <div onclick=\"{{ pickS0 }}\" style=\"{{ sStyle0 }}\"><div style=\"font-weight:700; font-size:15.5px;\">Recuse yourself — and tell the panel lead why.<\u002Fdiv><\u002Fdiv>\n          <div onclick=\"{{ pickS1 }}\" style=\"{{ sStyle1 }}\"><div style=\"font-weight:700; font-size:15.5px;\">Stay on the panel, but promise yourself you’ll be objective.<\u002Fdiv><\u002Fdiv>\n          <div onclick=\"{{ pickS2 }}\" style=\"{{ sStyle2 }}\"><div style=\"font-weight:700; font-size:15.5px;\">Quietly score her studio lower so you look neutral.<\u002Fdiv><\u002Fdiv>\n        <\u002Fdiv>\n\n        <sc-if value=\"{{ sAnswered }}\" hint-placeholder-val=\"{{ false }}\">\n        <div style=\"margin-top:16px; background:{{ sFbBg }}; border:1px solid {{ sFbBorder }}; border-radius:16px; padding:18px;\">\n          <div style=\"font-family:'Space Mono',monospace; font-size:12px; font-weight:700; color:{{ sFbAccent }};\">{{ sFbTag }}<\u002Fdiv>\n          <div style=\"font-size:15.5px; line-height:1.55; margin-top:7px; color:#211C17;\">{{ sFeedback }}<\u002Fdiv>\n          <div onclick=\"{{ next }}\" style=\"margin-top:14px; display:inline-block; background:#211C17; color:#fff; padding:11px 22px; border-radius:30px; font-weight:700; font-size:14px; cursor:pointer;\">Continue →<\u002Fdiv>\n        <\u002Fdiv>\n        <\u002Fsc-if>\n      <\u002Fdiv>\n      <\u002Fsc-if>\n\n      <!-- ===== QUIZ ===== -->\n      <sc-if value=\"{{ isQuiz }}\" hint-placeholder-val=\"{{ false }}\">\n      <div style=\"\">\n        <div style=\"display:inline-block; background:#fbe3d1; color:#c8611a; border-radius:20px; padding:4px 13px; font-family:'Space Mono',monospace; font-size:11px; font-weight:700;\">QUICK CHECK<\u002Fdiv>\n        <div style=\"font-family:'Unbounded',sans-serif; font-size:26px; font-weight:600; line-height:1.12; margin-top:14px; letter-spacing:-.01em;\">Which one actually needs disclosing?<\u002Fdiv>\n\n        <div style=\"margin-top:16px; display:flex; flex-direction:column; gap:11px;\">\n          <div onclick=\"{{ pickQ0 }}\" style=\"{{ qStyle0 }}\"><div style=\"font-weight:600; font-size:15.5px;\">Your partner works at a company Brindle will never deal with.<\u002Fdiv><\u002Fdiv>\n          <div onclick=\"{{ pickQ1 }}\" style=\"{{ qStyle1 }}\"><div style=\"font-weight:600; font-size:15.5px;\">You own shares in a supplier that’s bidding for a Brindle contract.<\u002Fdiv><\u002Fdiv>\n          <div onclick=\"{{ pickQ2 }}\" style=\"{{ qStyle2 }}\"><div style=\"font-weight:600; font-size:15.5px;\">You grabbed coffee with a coworker from another team.<\u002Fdiv><\u002Fdiv>\n        <\u002Fdiv>\n\n        <sc-if value=\"{{ qAnswered }}\" hint-placeholder-val=\"{{ false }}\">\n        <div style=\"margin-top:16px; background:{{ qFbBg }}; border:1px solid {{ qFbBorder }}; border-radius:16px; padding:18px;\">\n          <div style=\"font-family:'Space Mono',monospace; font-size:12px; font-weight:700; color:{{ qFbAccent }};\">{{ qFbTag }}<\u002Fdiv>\n          <div style=\"font-size:15.5px; line-height:1.55; margin-top:7px; color:#211C17;\">{{ qFeedback }}<\u002Fdiv>\n          <div onclick=\"{{ next }}\" style=\"margin-top:14px; display:inline-block; background:#211C17; color:#fff; padding:11px 22px; border-radius:30px; font-weight:700; font-size:14px; cursor:pointer;\">See your results →<\u002Fdiv>\n        <\u002Fdiv>\n        <\u002Fsc-if>\n      <\u002Fdiv>\n      <\u002Fsc-if>\n\n      <!-- ===== DONE ===== -->\n      <sc-if value=\"{{ isDone }}\" hint-placeholder-val=\"{{ false }}\">\n      <div style=\"\">\n        <div style=\"background:#2f6044; border-radius:24px; padding:38px 34px; color:#fff; text-align:center; position:relative; overflow:hidden;\">\n          <div style=\"font-size:46px;\">🎉<\u002Fdiv>\n          <div style=\"font-family:'Unbounded',sans-serif; font-size:30px; font-weight:700; margin-top:8px;\">Module complete<\u002Fdiv>\n          <div style=\"font-size:16px; color:#d5e7dc; margin-top:10px; line-height:1.5; max-width:420px; margin-left:auto; margin-right:auto;\">You can now spot a conflict, disclose it cleanly, and step back when you should. That’s the whole job.<\u002Fdiv>\n        <\u002Fdiv>\n        <div style=\"margin-top:18px; background:#fff; border:1px solid #ece0cc; border-radius:18px; padding:22px;\">\n          <div style=\"font-family:'Space Mono',monospace; font-size:12px; font-weight:700; color:#a59986; letter-spacing:.06em;\">YOUR THREE TAKEAWAYS<\u002Fdiv>\n          <div style=\"margin-top:14px; display:flex; flex-direction:column; gap:12px;\">\n            <div style=\"display:flex; gap:12px; align-items:flex-start;\"><div style=\"color:#E2701A; font-family:'Space Mono',monospace; font-weight:700;\">01<\u002Fdiv><div style=\"font-size:15.5px; line-height:1.5;\">A conflict only has to <em>look<\u002Fem> possible to count. Perception is the point.<\u002Fdiv><\u002Fdiv>\n            <div style=\"display:flex; gap:12px; align-items:flex-start;\"><div style=\"color:#E2701A; font-family:'Space Mono',monospace; font-weight:700;\">02<\u002Fdiv><div style=\"font-size:15.5px; line-height:1.5;\">Disclosing turns a problem into a non-issue. Hiding does the opposite.<\u002Fdiv><\u002Fdiv>\n            <div style=\"display:flex; gap:12px; align-items:flex-start;\"><div style=\"color:#E2701A; font-family:'Space Mono',monospace; font-weight:700;\">03<\u002Fdiv><div style=\"font-size:15.5px; line-height:1.5;\">When you benefit from a decision, let someone neutral make it.<\u002Fdiv><\u002Fdiv>\n          <\u002Fdiv>\n        <\u002Fdiv>\n        <div style=\"margin-top:18px; display:flex; gap:12px;\">\n          <div onclick=\"{{ restart }}\" style=\"padding:13px 24px; border-radius:30px; border:1px solid #ece0cc; background:#fff; font-weight:700; font-size:14px; cursor:pointer; color:#7A6F60;\">Replay module<\u002Fdiv>\n          <a href=\"#/Compass Portal.dc\" style=\"flex:1; text-decoration:none; text-align:center; padding:13px 24px; border-radius:30px; background:#E2701A; color:#fff; font-weight:700; font-size:14px;\">Back to Compass →<\u002Fa>\n        <\u002Fdiv>\n      <\u002Fdiv>\n      <\u002Fsc-if>\n\n      <!-- nav (teach steps) -->\n      <sc-if value=\"{{ showNav }}\" hint-placeholder-val=\"{{ false }}\">\n      <div style=\"margin-top:30px; display:flex; align-items:center; gap:12px;\">\n        <div onclick=\"{{ back }}\" style=\"padding:12px 22px; border-radius:30px; border:1px solid #ece0cc; background:#fff; font-weight:700; font-size:14px; cursor:pointer; color:#7A6F60;\">← Back<\u002Fdiv>\n        <div onclick=\"{{ next }}\" style=\"flex:1; text-align:center; padding:12px 22px; border-radius:30px; background:#211C17; color:#fff; font-weight:700; font-size:14px; cursor:pointer;\">Next →<\u002Fdiv>\n      <\u002Fdiv>\n      <\u002Fsc-if>\n\n    <\u002Fdiv>\n  <\u002Fdiv>\n<\u002Fdiv>\n\n<\u002Fx-dc>\n<script type=\"text/x-dc\" data-dc-script=\"\">\nclass Component extends DCLogic {\n  state = { step: 0, sPick: null, qPick: null };\n\n  KEY = 'brindle_training_step_v1';\n\n  componentDidMount() {\n    try {\n      const saved = parseInt(localStorage.getItem(this.KEY) || '0', 10);\n      if (saved > 0 && saved <= 6) this.setState({ step: saved });\n    } catch (e) {}\n  }\n\n  save(step) { try { localStorage.setItem(this.KEY, String(step)); } catch (e) {} }\n\n  teach = [\n    {\n      kicker: 'THE BASICS',\n      title: 'What even is a conflict?',\n      body: 'It\\u2019s when something in your personal life could sway a decision you make at work \\u2014 even if you\\u2019d never actually let it. Here\\u2019s the catch: the bias doesn\\u2019t have to be real. It just has to look possible to a reasonable outsider.',\n      block: 'pull'\n    },\n    {\n      kicker: 'KNOW THE SHAPES',\n      title: 'Three flavors you\\u2019ll actually run into',\n      body: 'Almost every conflict is one of these three. Learn the shapes and you\\u2019ll catch them early.',\n      block: 'flavors'\n    },\n    {\n      kicker: 'THE PLAYBOOK',\n      title: 'The move is always the same',\n      body: 'You don\\u2019t have to figure out if it\\u2019s \\u201Cbad enough.\\u201D You just have to surface it. Spot it, say it, step back \\u2014 and let someone without a stake make the call.',\n      block: 'steps'\n    }\n  ];\n\n  // step map: 0 cover, 1-3 teach, 4 scenario, 5 quiz, 6 done\n  go(step) { this.save(step); this.setState({ step }); window.scrollTo(0, 0); }\n\n  renderVals() {\n    const s = this.state.step;\n    const React = this.constructor.React || window.React;\n    const isTeach = s >= 1 && s <= 3;\n    const t = this.teach[s - 1] || this.teach[0];\n\n    // teach visual block\n    let tBlock = null;\n    const card = (bg, txt) => ({ background: bg, border: '1px solid #ece0cc', borderRadius: '14px', padding: '16px 18px' });\n    if (t.block === 'pull') {\n      tBlock = React.createElement('div', { style: { background:'#fff', border:'1px solid #ece0cc', borderRadius:'16px', padding:'22px', display:'flex', gap:'16px', alignItems:'center' } },\n        React.createElement('div', { style:{ fontSize:'40px' } }, '\\u2696\\uFE0F'),\n        React.createElement('div', { style:{ fontSize:'15px', color:'#43392f', lineHeight:1.55 } }, 'Picture a scale you\\u2019re holding. On one side: what\\u2019s best for Brindle. On the other: something good for you or someone you love. A conflict is just any weight on that second side \\u2014 reported or not.')\n      );\n    } else if (t.block === 'flavors') {\n      const f = (emoji, name, desc) => React.createElement('div', { style:{ background:'#fff', border:'1px solid #ece0cc', borderRadius:'16px', padding:'18px', flex:'1' } },\n        React.createElement('div', { style:{ fontSize:'24px' } }, emoji),\n        React.createElement('div', { style:{ fontFamily:\"'Unbounded',sans-serif\", fontWeight:600, fontSize:'16px', marginTop:'10px' } }, name),\n        React.createElement('div', { style:{ fontSize:'13.5px', color:'#7A6F60', marginTop:'6px', lineHeight:1.5 } }, desc)\n      );\n      tBlock = React.createElement('div', { style:{ display:'flex', gap:'12px' } },\n        f('\\uD83D\\uDCB0', 'Money', 'You or family profit from a work call \\u2014 like picking a vendor you hold stock in.'),\n        f('\\uD83D\\uDC65', 'People', 'A partner, relative, or close friend sits on the other side of your decision.'),\n        f('\\uD83D\\uDCBC', 'Outside gigs', 'A side job or board seat that competes for your time, loyalty, or info.')\n      );\n    } else if (t.block === 'steps') {\n      const stepRow = (n, title, desc, color) => React.createElement('div', { style:{ background:'#fff', border:'1px solid #ece0cc', borderRadius:'16px', padding:'18px', display:'flex', gap:'14px', alignItems:'flex-start' } },\n        React.createElement('div', { style:{ width:'30px', height:'30px', flexShrink:0, borderRadius:'50%', background:color, color:'#fff', display:'flex', alignItems:'center', justifyContent:'center', fontWeight:800, fontSize:'14px' } }, n),\n        React.createElement('div', null,\n          React.createElement('div', { style:{ fontWeight:700, fontSize:'15.5px' } }, title),\n          React.createElement('div', { style:{ fontSize:'14px', color:'#7A6F60', marginTop:'3px', lineHeight:1.5 } }, desc)\n        )\n      );\n      tBlock = React.createElement('div', { style:{ display:'flex', flexDirection:'column', gap:'11px' } },\n        stepRow('1', 'Spot it', 'Notice the tug before you act. If you benefit, slow down.', '#E2701A'),\n        stepRow('2', 'Say it', 'Tell your manager and log it in Compass. Two minutes, in writing.', '#6B4FB0'),\n        stepRow('3', 'Step back', 'Hand the decision to someone neutral. Done \\u2014 it\\u2019s no longer a problem.', '#2f6044')\n      );\n    }\n\n    // scenario\n    const sVerdicts = ['good', 'bad', 'bad'];\n    const sFb = [\n      'Exactly. Disclose plus step back. Her studio can still compete fairly, and no one can ever question the outcome.',\n      'Good intentions aren\\u2019t enough. Even if you\\u2019re perfectly fair, it looks compromised \\u2014 and that\\u2019s the whole problem. Disclose and recuse.',\n      'Now you\\u2019ve created a second problem. Overcorrecting isn\\u2019t fair either. The clean answer is to disclose and step out of the decision.'\n    ];\n    const optStyle = (picked, isPicked, isAnswered, verdict) => {\n      const base = 'background:#fff; border:1.5px solid #ece0cc; border-radius:14px; padding:16px 18px; cursor:pointer;';\n      if (!isAnswered) return base;\n      if (isPicked) {\n        if (verdict === 'good') return 'background:#e9f4ec; border:1.5px solid #2f6044; border-radius:14px; padding:16px 18px; cursor:pointer;';\n        return 'background:#fbe6e0; border:1.5px solid #c14b3a; border-radius:14px; padding:16px 18px; cursor:pointer;';\n      }\n      return 'background:#fff; border:1.5px solid #ece0cc; border-radius:14px; padding:16px 18px; cursor:pointer; opacity:.55;';\n    };\n    const sAnswered = this.state.sPick !== null;\n    const sV = sAnswered ? sVerdicts[this.state.sPick] : null;\n\n    // quiz (index 1 correct)\n    const qFb = [\n      'Not this one \\u2014 unrelated company, zero overlap. Nothing to disclose, carry on.',\n      'Yep. A financial stake in a company that\\u2019s bidding is a textbook conflict. Disclose it before any decision gets made.',\n      'Nope \\u2014 a coffee isn\\u2019t a conflict. Save your disclosures for real stakes.'\n    ];\n    const qAnswered = this.state.qPick !== null;\n    const qCorrectIdx = 1;\n    const qOptStyle = (i) => {\n      const base = 'background:#fff; border:1.5px solid #ece0cc; border-radius:14px; padding:16px 18px; cursor:pointer;';\n      if (!qAnswered) return base;\n      if (i === qCorrectIdx) return 'background:#e9f4ec; border:1.5px solid #2f6044; border-radius:14px; padding:16px 18px; cursor:pointer;';\n      if (i === this.state.qPick) return 'background:#fbe6e0; border:1.5px solid #c14b3a; border-radius:14px; padding:16px 18px; cursor:pointer;';\n      return 'background:#fff; border:1.5px solid #ece0cc; border-radius:14px; padding:16px 18px; cursor:pointer; opacity:.55;';\n    };\n    const qRight = qAnswered && this.state.qPick === qCorrectIdx;\n\n    const progress = s === 0 ? 0 : Math.round((Math.min(s, 5) / 5) * 100);\n\n    return {\n      isCover: s === 0, isTeach, isScenario: s === 4, isQuiz: s === 5, isDone: s === 6,\n      showNav: isTeach,\n      stepKey: 't' + s,\n      progressPct: progress + '%',\n      progressLabel: s === 0 ? 'Not started' : (s >= 6 ? 'Complete' : 'Step ' + Math.min(s,5) + ' of 5'),\n      start: () => this.go(1),\n      next: () => this.go(Math.min(6, s + 1)),\n      back: () => this.go(Math.max(0, s - 1)),\n      restart: () => { this.setState({ sPick: null, qPick: null }); this.go(0); },\n      tKicker: t.kicker, tTitle: t.title, tBody: t.body, tBlock,\n      // scenario\n      pickS0: () => this.setState({ sPick: 0 }),\n      pickS1: () => this.setState({ sPick: 1 }),\n      pickS2: () => this.setState({ sPick: 2 }),\n      sStyle0: optStyle(this.state.sPick, this.state.sPick===0, sAnswered, sVerdicts[0]),\n      sStyle1: optStyle(this.state.sPick, this.state.sPick===1, sAnswered, sVerdicts[1]),\n      sStyle2: optStyle(this.state.sPick, this.state.sPick===2, sAnswered, sVerdicts[2]),\n      sAnswered,\n      sFeedback: sAnswered ? sFb[this.state.sPick] : '',\n      sFbTag: sV === 'good' ? 'NICE CALL' : 'NOT QUITE',\n      sFbBg: sV === 'good' ? '#e9f4ec' : '#fbe6e0',\n      sFbBorder: sV === 'good' ? '#bfe0cc' : '#f0cabf',\n      sFbAccent: sV === 'good' ? '#2f6044' : '#c14b3a',\n      // quiz\n      pickQ0: () => this.setState({ qPick: 0 }),\n      pickQ1: () => this.setState({ qPick: 1 }),\n      pickQ2: () => this.setState({ qPick: 2 }),\n      qStyle0: qOptStyle(0), qStyle1: qOptStyle(1), qStyle2: qOptStyle(2),\n      qAnswered,\n      qFeedback: qAnswered ? qFb[this.state.qPick] : '',\n      qFbTag: qRight ? 'CORRECT' : 'CLOSE',\n      qFbBg: qRight ? '#e9f4ec' : '#fbe6e0',\n      qFbBorder: qRight ? '#bfe0cc' : '#f0cabf',\n      qFbAccent: qRight ? '#2f6044' : '#c14b3a'\n    };\n  }\n}\n<\u002Fscript>\n\n\n<\u002Fbody><\u002Fhtml>","Animated Explainer.dc":"<!DOCTYPE html>\n<html><head>\n<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n<script src=\"784ac927-7ef4-471f-ad5b-89505a8cf4d4\"><\u002Fscript>\n<\u002Fhead>\n<body>\n<x-dc>\n<helmet>\n<link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\n<link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin=\"\">\n<style>/* cyrillic-ext */\n@font-face {\n  font-family: 'Hanken Grotesk';\n  font-style: normal;\n  font-weight: 400;\n  font-display: swap;\n  src: url(\"bcabb077-c77c-4b2c-a6ea-deb9e037ec92\") format('woff2');\n  unicode-range: U+0460-052F, U+1C80-1C8A, U+20B4, U+2DE0-2DFF, U+A640-A69F, U+FE2E-FE2F;\n}\n/* vietnamese */\n@font-face {\n  font-family: 'Hanken Grotesk';\n  font-style: normal;\n  font-weight: 400;\n  font-display: swap;\n  src: url(\"861ea967-68a0-453a-b62a-31cc1c986d8c\") format('woff2');\n  unicode-range: U+0102-0103, U+0110-0111, U+0128-0129, U+0168-0169, U+01A0-01A1, U+01AF-01B0, U+0300-0301, U+0303-0304, U+0308-0309, U+0323, U+0329, U+1EA0-1EF9, U+20AB;\n}\n/* latin-ext */\n@font-face {\n  font-family: 'Hanken Grotesk';\n  font-style: normal;\n  font-weight: 400;\n  font-display: swap;\n  src: url(\"0cd27b4d-b03c-4214-9534-72512e8b0ce4\") format('woff2');\n  unicode-range: U+0100-02BA, U+02BD-02C5, U+02C7-02CC, U+02CE-02D7, U+02DD-02FF, U+0304, U+0308, U+0329, U+1D00-1DBF, U+1E00-1E9F, U+1EF2-1EFF, U+2020, U+20A0-20AB, U+20AD-20C0, U+2113, U+2C60-2C7F, U+A720-A7FF;\n}\n/* latin */\n@font-face {\n  font-family: 'Hanken Grotesk';\n  font-style: normal;\n  font-weight: 400;\n  font-display: swap;\n  src: url(\"6131583b-fdee-4dbf-9591-b79a5f1628f4\") format