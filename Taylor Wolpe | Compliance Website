U+FFFD;\n}\n<\u002Fstyle>\n<style>\n  * { box-sizing: border-box; }\n  html, body { margin: 0; background:#FBF6EE; }\n  @keyframes cxspin { to { transform: rotate(360deg); } }\n  @keyframes cxtip { from { transform: rotate(-11deg); } to { transform: rotate(11deg); } }\n  @keyframes cxpulse { 0%,100% { transform: translateY(0); } 50% { transform: translateY(-5px); } }\n<\u002Fstyle>\n<\u002Fhelmet>\n\n<div style=\"min-height:100vh; background:#FBF6EE; font-family:'Hanken Grotesk',sans-serif; color:#211C17; display:flex; flex-direction:column;\">\n\n  <div style=\"background:#211C17; color:#f1ead9; text-align:center; padding:8px 16px; font-family:'Space Mono',monospace; font-size:11.5px; letter-spacing:.03em; line-height:1.4;\">FICTIONAL SAMPLE · A motion-design concept by Taylor Wolpe — “Brindle Beverage Co.” is invented, not a real company.<\u002Fdiv>\n\n  <div style=\"flex:1; display:flex; flex-direction:column; align-items:center; padding:30px 24px 50px;\">\n    <div style=\"width:100%; max-width:900px;\">\n      <div style=\"display:flex; align-items:center; justify-content:space-between; margin-bottom:14px;\">\n        <div style=\"display:flex; align-items:center; gap:9px;\">\n          <div style=\"width:30px; height:30px; border-radius:50%; background:#211C17; display:flex; align-items:center; justify-content:center; position:relative;\"><div style=\"width:0; height:0; border-left:4px solid transparent; border-right:4px solid transparent; border-bottom:11px solid #E2701A; transform:translateY(-2px) rotate(40deg);\"><\u002Fdiv><\u002Fdiv>\n          <div style=\"font-family:'Space Mono',monospace; font-size:12px; font-weight:700; color:#7A6F60; letter-spacing:.04em;\">COMPASS · ANIMATED EXPLAINER<\u002Fdiv>\n        <\u002Fdiv>\n        <div style=\"font-family:'Space Mono',monospace; font-size:12px; color:#a59986;\">Conflicts of Interest<\u002Fdiv>\n      <\u002Fdiv>\n\n      <!-- STAGE -->\n      <div id=\"cx-stage\" style=\"position:relative; width:100%; aspect-ratio:16/9; background:#1b1714; border-radius:20px; overflow:hidden; box-shadow:0 20px 50px rgba(33,28,23,.28);\">\n        <!-- bg ring -->\n        <div id=\"cx-ring\" data-anim=\"1\" style=\"position:absolute; right:-90px; bottom:-110px; width:340px; height:340px; border-radius:50%; border:30px solid #E2701A; opacity:.07; animation:cxspin 60s linear infinite;\"><\u002Fdiv>\n        <div style=\"position:absolute; left:-70px; top:-90px; width:240px; height:240px; border-radius:50%; background:#6B4FB0; opacity:.10; filter:blur(10px);\"><\u002Fdiv>\n\n        <!-- SCENE 0 -->\n        <div id=\"cx-scene-0\" style=\"position:absolute; inset:0; display:flex; flex-direction:column; align-items:center; justify-content:center; text-align:center; padding:8%; opacity:1;\">\n          <div style=\"font-family:'Space Mono',monospace; font-size:14px; letter-spacing:.18em; color:#E2701A; font-weight:700;\">A 60-SECOND BRIEF<\u002Fdiv>\n          <div style=\"font-family:'Unbounded',sans-serif; font-weight:800; font-size:54px; line-height:1.02; letter-spacing:-.03em; color:#FBF6EE; margin-top:18px;\">Conflicts of<br>Interest<\u002Fdiv>\n          <div style=\"width:60px; height:4px; background:#E2701A; border-radius:3px; margin-top:24px;\"><\u002Fdiv>\n          <div style=\"font-size:18px; color:#b6ada2; margin-top:18px;\">The whole idea, in about a minute.<\u002Fdiv>\n        <\u002Fdiv>\n\n        <!-- SCENE 1 -->\n        <div id=\"cx-scene-1\" style=\"position:absolute; inset:0; display:flex; flex-direction:column; align-items:center; justify-content:center; text-align:center; padding:9%; opacity:0;\">\n          <div id=\"cx-scale\" style=\"position:relative; width:170px; height:96px; margin-bottom:26px;\">\n            <div id=\"cx-beam\" data-anim=\"1\" style=\"position:absolute; top:20px; left:15px; width:140px; height:7px; background:#E2701A; border-radius:5px; transform-origin:50% 50%; animation:cxtip 3.4s ease-in-out infinite alternate;\">\n              <div style=\"position:absolute; left:-7px; top:-6px; width:18px; height:18px; border-radius:50%; background:#f6efe3;\"><\u002Fdiv>\n              <div style=\"position:absolute; right:-7px; top:-6px; width:18px; height:18px; border-radius:50%; background:#6B4FB0;\"><\u002Fdiv>\n            <\u002Fdiv>\n            <div style=\"position:absolute; top:26px; left:73px; width:0; height:0; border-left:14px solid transparent; border-right:14px solid transparent; border-bottom:50px solid #4a423b;\"><\u002Fdiv>\n          <\u002Fdiv>\n          <div style=\"font-family:'Unbounded',sans-serif; font-weight:600; font-size:32px; line-height:1.2; letter-spacing:-.02em; color:#FBF6EE; max-width:680px;\">It’s when your <span style=\"color:#E2701A;\">personal life<\u002Fspan> could tug at a decision you make at work.<\u002Fdiv>\n        <\u002Fdiv>\n\n        <!-- SCENE 2 -->\n        <div id=\"cx-scene-2\" style=\"position:absolute; inset:0; display:flex; flex-direction:column; align-items:center; justify-content:center; text-align:center; padding:9%; opacity:0;\">\n          <div style=\"font-family:'Space Mono',monospace; font-size:14px; letter-spacing:.16em; color:#6B4FB0; font-weight:700;\">HERE’S THE CATCH<\u002Fdiv>\n          <div style=\"font-family:'Unbounded',sans-serif; font-weight:600; font-size:34px; line-height:1.18; letter-spacing:-.02em; color:#FBF6EE; max-width:720px; margin-top:18px;\">It doesn’t matter if you’d actually stay fair.<br><span style=\"color:#E2701A;\">If it could look biased, it counts.<\u002Fspan><\u002Fdiv>\n        <\u002Fdiv>\n\n        <!-- SCENE 3 -->\n        <div id=\"cx-scene-3\" style=\"position:absolute; inset:0; display:flex; flex-direction:column; align-items:center; justify-content:center; text-align:center; padding:9%; opacity:0;\">\n          <div style=\"font-family:'Unbounded',sans-serif; font-weight:700; font-size:40px; line-height:1.12; letter-spacing:-.02em; color:#FBF6EE; max-width:720px;\">Having one is <span style=\"color:#6FB58A;\">normal.<\u002Fspan><br>Hiding it is the <span style=\"color:#E2701A;\">problem.<\u002Fspan><\u002Fdiv>\n        <\u002Fdiv>\n\n        <!-- SCENE 4 -->\n        <div id=\"cx-scene-4\" style=\"position:absolute; inset:0; display:flex; flex-direction:column; align-items:center; justify-content:center; text-align:center; padding:7%; opacity:0;\">\n          <div style=\"font-size:19px; color:#b6ada2;\">So the move is always the same:<\u002Fdiv>\n          <div style=\"display:flex; gap:16px; margin-top:26px; flex-wrap:wrap; justify-content:center;\">\n            <div data-anim=\"1\" style=\"background:rgba(226,112,26,.14); border:1.5px solid #E2701A; color:#E2701A; border-radius:16px; padding:18px 26px; animation:cxpulse 2.6s ease-in-out infinite;\"><div style=\"font-family:'Space Mono',monospace; font-size:12px; opacity:.8;\">01<\u002Fdiv><div style=\"font-family:'Unbounded',sans-serif; font-weight:700; font-size:24px; margin-top:4px;\">Spot it<\u002Fdiv><\u002Fdiv>\n            <div data-anim=\"1\" style=\"background:rgba(107,79,176,.16); border:1.5px solid #8a6fd0; color:#c3b1f0; border-radius:16px; padding:18px 26px; animation:cxpulse 2.6s ease-in-out infinite .3s;\"><div style=\"font-family:'Space Mono',monospace; font-size:12px; opacity:.8;\">02<\u002Fdiv><div style=\"font-family:'Unbounded',sans-serif; font-weight:700; font-size:24px; margin-top:4px;\">Say it<\u002Fdiv><\u002Fdiv>\n            <div data-anim=\"1\" style=\"background:rgba(111,181,138,.16); border:1.5px solid #6FB58A; color:#9fd6b6; border-radius:16px; padding:18px 26px; animation:cxpulse 2.6s ease-in-out infinite .6s;\"><div style=\"font-family:'Space Mono',monospace; font-size:12px; opacity:.8;\">03<\u002Fdiv><div style=\"font-family:'Unbounded',sans-serif; font-weight:700; font-size:24px; margin-top:4px;\">Step back<\u002Fdiv><\u002Fdiv>\n          <\u002Fdiv>\n          <div style=\"font-size:16px; color:#8a8077; margin-top:26px; max-width:560px;\">Surface it, put it in writing, and let someone neutral make the call.<\u002Fdiv>\n        <\u002Fdiv>\n\n        <!-- SCENE 5 -->\n        <div id=\"cx-scene-5\" style=\"position:absolute; inset:0; display:flex; flex-direction:column; align-items:center; justify-content:center; text-align:center; padding:8%; opacity:0;\">\n          <div style=\"font-family:'Unbounded',sans-serif; font-weight:800; font-size:46px; line-height:1.05; letter-spacing:-.03em; color:#FBF6EE;\">When in doubt,<br><span style=\"color:#E2701A;\">disclose.<\u002Fspan><\u002Fdiv>\n          <div style=\"display:flex; align-items:center; gap:10px; margin-top:30px;\">\n            <div style=\"width:26px; height:26px; border-radius:50%; background:#FBF6EE; display:flex; align-items:center; justify-content:center; position:relative;\"><div style=\"width:0; height:0; border-left:3.5px solid transparent; border-right:3.5px solid transparent; border-bottom:9px solid #E2701A; transform:translateY(-1px) rotate(40deg);\"><\u002Fdiv><\u002Fdiv>\n            <div style=\"font-family:'Space Mono',monospace; font-size:12px; letter-spacing:.1em; color:#8a8077;\">COMPASS · BRINDLE BEVERAGE CO. ETHICS HUB<\u002Fdiv>\n          <\u002Fdiv>\n        <\u002Fdiv>\n      <\u002Fdiv>\n\n      <!-- CONTROLS -->\n      <div style=\"margin-top:16px; display:flex; align-items:center; gap:16px;\">\n        <div onclick=\"{{ togglePlay }}\" style=\"width:46px; height:46px; flex-shrink:0; border-radius:50%; background:#E2701A; color:#fff; display:flex; align-items:center; justify-content:center; cursor:pointer; font-size:14px;\"><span id=\"cx-playicon\">❚❚<\u002Fspan><\u002Fdiv>\n        <div onclick=\"{{ restart }}\" style=\"width:42px; height:42px; flex-shrink:0; border-radius:50%; border:1px solid #ece0cc; background:#fff; color:#7A6F60; display:flex; align-items:center; justify-content:center; cursor:pointer; font-size:16px;\">↻<\u002Fdiv>\n        <div onclick=\"{{ seek }}\" style=\"flex:1; height:24px; display:flex; align-items:center; cursor:pointer;\">\n          <div style=\"width:100%; height:7px; background:#ece0cc; border-radius:5px; overflow:hidden;\"><div id=\"cx-prog\" style=\"width:0%; height:100%; background:#E2701A;\"><\u002Fdiv><\u002Fdiv>\n        <\u002Fdiv>\n        <div id=\"cx-time\" style=\"font-family:'Space Mono',monospace; font-size:12px; color:#a59986; flex-shrink:0; width:74px; text-align:right;\">0:00 / 0:32<\u002Fdiv>\n      <\u002Fdiv>\n\n      <div style=\"margin-top:14px; font-size:13.5px; color:#9a8e7e; text-align:center; max-width:620px; margin-left:auto; margin-right:auto; line-height:1.5;\">A short kinetic explainer designed to make a dry policy topic land in under a minute — the kind of asset that turns a 30-page handbook into something people actually watch.<\u002Fdiv>\n    <\u002Fdiv>\n  <\u002Fdiv>\n<\u002Fdiv>\n\n<\u002Fx-dc>\n<script type=\"text/x-dc\" data-dc-script=\"\">\nclass Component extends DCLogic {\n  scenes = [5, 5.5, 5, 5, 6.5, 5];\n  KEY = 'brindle_explainer_t_v1';\n\n  componentDidMount() {\n    this.total = this.scenes.reduce((a, b) => a + b, 0);\n    this.t = 0;\n    this.playing = true;\n    this.last = null;\n    try {\n      const s = parseFloat(localStorage.getItem(this.KEY));\n      if (s > 0 && s < this.total) { this.t = s; }\n    } catch (e) {}\n    this.loop = this.loop.bind(this);\n    this.raf = requestAnimationFrame(this.loop);\n  }\n  componentWillUnmount() { if (this.raf) cancelAnimationFrame(this.raf); }\n\n  fmt(s) { s = Math.max(0, Math.floor(s)); return '0:' + String(s).padStart(2, '0'); }\n\n  loop(ts) {\n    if (this.last == null) this.last = ts;\n    const dt = (ts - this.last) / 1000; this.last = ts;\n    if (this.playing) {\n      this.t += dt;\n      if (this.t >= this.total) { this.t = this.total; this.playing = false; }\n      if (Math.floor(this.t * 4) !== this._sv) { this._sv = Math.floor(this.t * 4); try { localStorage.setItem(this.KEY, String(this.t)); } catch (e) {} }\n    }\n    this.draw();\n    this.raf = requestAnimationFrame(this.loop);\n  }\n\n  draw() {\n    const prog = document.getElementById('cx-prog');\n    if (prog) prog.style.width = (this.t / this.total * 100).toFixed(2) + '%';\n    const tl = document.getElementById('cx-time');\n    if (tl) tl.textContent = this.fmt(this.t) + ' / ' + this.fmt(this.total);\n    const fade = 0.55;\n    let acc = 0;\n    for (let i = 0; i < this.scenes.length; i++) {\n      const d = this.scenes[i], start = acc, end = acc + d; acc += d;\n      const el = document.getElementById('cx-scene-' + i);\n      if (!el) continue;\n      let op = 0, ty = 18;\n      if (this.t >= start && this.t <= end) {\n        const isLast = i === this.scenes.length - 1;\n        const fin = Math.min(1, (this.t - start) / fade);\n        const fout = isLast ? 1 : Math.min(1, (end - this.t) / fade);\n        op = Math.min(fin, fout);\n        ty = 18 * (1 - fin) - 14 * (1 - fout);\n        el.style.zIndex = 2;\n      } else {\n        op = 0; el.style.zIndex = 1; ty = this.t < start ? 18 : -14;\n      }\n      el.style.opacity = op.toFixed(3);\n      el.style.transform = 'translateY(' + ty.toFixed(1) + 'px)';\n    }\n    const ps = this.playing ? 'running' : 'paused';\n    document.querySelectorAll('[data-anim]').forEach(e => { e.style.animationPlayState = ps; });\n    const pi = document.getElementById('cx-playicon');\n    if (pi) pi.innerHTML = this.playing ? '&#10074;&#10074;' : '&#9654;';\n  }\n\n  renderVals() {\n    return {\n      togglePlay: () => {\n        if (this.t >= this.total) { this.t = 0; this.last = null; this.playing = true; }\n        else { this.playing = !this.playing; }\n        this.draw();\n      },\n      restart: () => { this.t = 0; this.last = null; this.playing = true; this.draw(); },\n      seek: (e) => {\n        const track = e.currentTarget;\n        const rect = track.getBoundingClientRect();\n        const frac = Math.min(1, Math.max(0, (e.clientX - rect.left) / rect.width));\n        this.t = frac * this.total;\n        this.last = null;\n        if (this.t >= this.total) this.playing = false;\n        this.draw();\n      }\n    };\n  }\n}\n<\u002Fscript>\n\n\n<\u002Fbody><\u002Fhtml>"},"entry":"Portfolio.dc"}
