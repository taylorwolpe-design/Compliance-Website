yle=\"margin-top:34px; display:grid; grid-template-columns:1fr 260px; gap:32px;\">\n      <div>\n        <div style=\"font-family:'Unbounded',sans-serif; font-size:21px; font-weight:600; letter-spacing:-.01em;\">The 10-second test<\u002Fdiv>\n        <div style=\"font-size:15px; color:#7A6F60; margin-top:8px; line-height:1.6;\">Before you act, run these three. If any one makes you hesitate — that’s your signal to check with us.<\u002Fdiv>\n        <div style=\"margin-top:18px; display:flex; flex-direction:column; gap:12px;\">\n          <div style=\"background:#fff; border:1px solid #ece0cc; border-radius:16px; padding:18px; display:flex; gap:15px; align-items:flex-start; box-shadow:0 4px 14px rgba(120,80,30,.05);\"><div style=\"width:28px; height:28px; flex-shrink:0; border-radius:50%; background:#fbe3d1; color:#c8611a; display:flex; align-items:center; justify-content:center; font-weight:800; font-size:14px;\">1<\u002Fdiv><div style=\"font-size:16px; line-height:1.5;\">{{ pQ1 }}<\u002Fdiv><\u002Fdiv>\n          <div style=\"background:#fff; border:1px solid #ece0cc; border-radius:16px; padding:18px; display:flex; gap:15px; align-items:flex-start; box-shadow:0 4px 14px rgba(120,80,30,.05);\"><div style=\"width:28px; height:28px; flex-shrink:0; border-radius:50%; background:#ece7f7; color:#6B4FB0; display:flex; align-items:center; justify-content:center; font-weight:800; font-size:14px;\">2<\u002Fdiv><div style=\"font-size:16px; line-height:1.5;\">{{ pQ2 }}<\u002Fdiv><\u002Fdiv>\n          <div style=\"background:#fff; border:1px solid #ece0cc; border-radius:16px; padding:18px; display:flex; gap:15px; align-items:flex-start; box-shadow:0 4px 14px rgba(120,80,30,.05);\"><div style=\"width:28px; height:28px; flex-shrink:0; border-radius:50%; background:#e4efe8; color:#2f6044; display:flex; align-items:center; justify-content:center; font-weight:800; font-size:14px;\">3<\u002Fdiv><div style=\"font-size:16px; line-height:1.5;\">{{ pQ3 }}<\u002Fdiv><\u002Fdiv>\n        <\u002Fdiv>\n\n        <div style=\"font-family:'Unbounded',sans-serif; font-size:21px; font-weight:600; margin-top:36px; letter-spacing:-.01em;\">Real situations<\u002Fdiv>\n        <div style=\"font-size:15px; color:#7A6F60; margin-top:8px; line-height:1.6;\">Same kind of moment, three different endings.<\u002Fdiv>\n        <div style=\"margin-top:18px; display:flex; flex-direction:column; gap:14px;\">\n          <div style=\"background:#fff; border:1px solid #ece0cc; border-radius:16px; padding:18px; box-shadow:0 4px 14px rgba(120,80,30,.05);\"><div style=\"display:inline-block; background:#e4efe8; color:#2f6044; border-radius:20px; padding:3px 12px; font-family:'Space Mono',monospace; font-size:11px; font-weight:700;\">GO FOR IT<\u002Fdiv><div style=\"font-size:15.5px; line-height:1.55; margin-top:10px;\">{{ pOk }}<\u002Fdiv><\u002Fdiv>\n          <div style=\"background:#fff; border:1px solid #ece0cc; border-radius:16px; padding:18px; box-shadow:0 4px 14px rgba(120,80,30,.05);\"><div style=\"display:inline-block; background:#fbeccb; color:#a9772a; border-radius:20px; padding:3px 12px; font-family:'Space Mono',monospace; font-size:11px; font-weight:700;\">PAUSE &amp; ASK<\u002Fdiv><div style=\"font-size:15.5px; line-height:1.55; margin-top:10px;\">{{ pPause }}<\u002Fdiv><\u002Fdiv>\n          <div style=\"background:#fff; border:1px solid #ece0cc; border-radius:16px; padding:18px; box-shadow:0 4px 14px rgba(120,80,30,.05);\"><div style=\"display:inline-block; background:#fbe0db; color:#b5224a; border-radius:20px; padding:3px 12px; font-family:'Space Mono',monospace; font-size:11px; font-weight:700;\">HARD NO<\u002Fdiv><div style=\"font-size:15.5px; line-height:1.55; margin-top:10px;\">{{ pNo }}<\u002Fdiv><\u002Fdiv>\n        <\u002Fdiv>\n      <\u002Fdiv>\n\n      <div>\n        <div style=\"position:sticky; top:90px;\">\n          <div style=\"background:#211C17; border-radius:18px; padding:22px;\">\n            <div style=\"font-family:'Unbounded',sans-serif; font-size:16px; font-weight:600; color:#fff;\">How to disclose<\u002Fdiv>\n            <div style=\"margin-top:14px; display:flex; flex-direction:column; gap:14px;\">\n              <div style=\"display:flex; gap:11px; align-items:flex-start;\"><div style=\"color:#E2701A; font-family:'Space Mono',monospace; font-weight:700; font-size:13px;\">01<\u002Fdiv><div style=\"font-size:14px; color:#c2bbb2; line-height:1.5;\">Tell your manager the moment you spot it.<\u002Fdiv><\u002Fdiv>\n              <div style=\"display:flex; gap:11px; align-items:flex-start;\"><div style=\"color:#E2701A; font-family:'Space Mono',monospace; font-weight:700; font-size:13px;\">02<\u002Fdiv><div style=\"font-size:14px; color:#c2bbb2; line-height:1.5;\">Log it in Compass — takes two minutes.<\u002Fdiv><\u002Fdiv>\n              <div style=\"display:flex; gap:11px; align-items:flex-start;\"><div style=\"color:#E2701A; font-family:'Space Mono',monospace; font-weight:700; font-size:13px;\">03<\u002Fdiv><div style=\"font-size:14px; color:#c2bbb2; line-height:1.5;\">We confirm a plan with you in writing.<\u002Fdiv><\u002Fdiv>\n            <\u002Fdiv>\n            <div onclick=\"{{ openSpeakUp }}\" style=\"margin-top:18px; background:#E2701A; color:#fff; text-align:center; padding:11px; border-radius:30px; font-weight:700; font-size:14px; cursor:pointer;\">Disclose now<\u002Fdiv>\n          <\u002Fdiv>\n        <\u002Fdiv>\n      <\u002Fdiv>\n    <\u002Fdiv>\n  <\u002Fdiv>\n  <\u002Fsc-if>\n\n  <!-- ===== SPEAK UP ===== -->\n  <sc-if value=\"{{ isSpeakUp }}\" hint-placeholder-val=\"{{ false }}\">\n  <div style=\"max-width:640px; margin:0 auto; padding:50px 28px 70px;\">\n    <div onclick=\"{{ goHome }}\" style=\"display:inline-flex; align-items:center; gap:7px; font-family:'Space Mono',monospace; font-size:13px; font-weight:700; cursor:pointer; margin-bottom:22px; color:#7A6F60;\">← BACK<\u002Fdiv>\n    <div style=\"background:#2f6044; color:#fff; border-radius:22px; padding:34px;\">\n      <div style=\"font-family:'Space Mono',monospace; font-size:12px; font-weight:700; letter-spacing:.06em; color:#bfe0cc;\">CONFIDENTIAL · NO RETALIATION<\u002Fdiv>\n      <div style=\"font-family:'Unbounded',sans-serif; font-size:32px; font-weight:700; margin-top:12px; line-height:1.05;\">Speak up. We’ve got you.<\u002Fdiv>\n      <div style=\"font-size:16px; color:#d5e7dc; margin-top:14px; line-height:1.5;\">Raise anything — a question, a worry, or something you saw. Share your name or stay anonymous. Either way, we follow up and protect you.<\u002Fdiv>\n    <\u002Fdiv>\n    <div style=\"margin-top:20px; display:flex; flex-direction:column; gap:14px;\">\n      <div style=\"background:#fff; border:1px solid #ece0cc; border-radius:16px; padding:18px 20px; display:flex; align-items:center; gap:16px; box-shadow:0 4px 14px rgba(120,80,30,.05); cursor:pointer;\"><div style=\"font-size:24px;\">💬<\u002Fdiv><div><div style=\"font-family:'Unbounded',sans-serif; font-weight:600; font-size:16px;\">Ask a question<\u002Fdiv><div style=\"font-size:14px; color:#7A6F60; margin-top:2px;\">Not sure if something’s a problem? Just ask.<\u002Fdiv><\u002Fdiv><\u002Fdiv>\n      <div style=\"background:#fff; border:1px solid #ece0cc; border-radius:16px; padding:18px 20px; display:flex; align-items:center; gap:16px; box-shadow:0 4px 14px rgba(120,80,30,.05); cursor:pointer;\"><div style=\"font-size:24px;\">⚠️<\u002Fdiv><div><div style=\"font-family:'Unbounded',sans-serif; font-weight:600; font-size:16px;\">Report a concern<\u002Fdiv><div style=\"font-size:14px; color:#7A6F60; margin-top:2px;\">Flag something that doesn’t sit right.<\u002Fdiv><\u002Fdiv><\u002Fdiv>\n      <div style=\"background:#fff; border:1px solid #ece0cc; border-radius:16px; padding:18px 20px; display:flex; align-items:center; gap:16px; box-shadow:0 4px 14px rgba(120,80,30,.05); cursor:pointer;\"><div style=\"font-size:24px;\">🛡️<\u002Fdiv><div><div style=\"font-family:'Unbounded',sans-serif; font-weight:600; font-size:16px;\">Report anonymously<\u002Fdiv><div style=\"font-size:14px; color:#7A6F60; margin-top:2px;\">Run by an independent third party.<\u002Fdiv><\u002Fdiv><\u002Fdiv>\n    <\u002Fdiv>\n  <\u002Fdiv>\n  <\u002Fsc-if>\n\n  <!-- ===== DECISION GUIDE OVERLAY ===== -->\n  <sc-if value=\"{{ guideOpen }}\" hint-placeholder-val=\"{{ false }}\">\n  <div style=\"position:fixed; inset:0; z-index:50; background:rgba(33,28,23,.5); backdrop-filter:blur(3px); display:flex; align-items:center; justify-content:center; padding:24px;\">\n    <div style=\"background:#FBF6EE; border-radius:22px; width:100%; max-width:560px; box-shadow:0 30px 70px rgba(33,28,23,.35); overflow:hidden;\">\n      <div style=\"background:#211C17; padding:18px 24px; display:flex; align-items:center; justify-content:space-between;\">\n        <div style=\"font-family:'Unbounded',sans-serif; color:#E2701A; font-weight:600; font-size:16px;\">Decision guide<\u002Fdiv>\n        <div onclick=\"{{ closeGuide }}\" style=\"color:#fff; cursor:pointer; font-size:22px; line-height:1;\">×<\u002Fdiv>\n      <\u002Fdiv>\n      <div style=\"padding:18px 24px 0; display:flex; gap:6px;\">\n        <div style=\"flex:1; height:6px; border-radius:4px; background:{{ gb0 }};\"><\u002Fdiv>\n        <div style=\"flex:1; height:6px; border-radius:4px; background:{{ gb1 }};\"><\u002Fdiv>\n        <div style=\"flex:1; height:6px; border-radius:4px; background:{{ gb2 }};\"><\u002Fdiv>\n        <div style=\"flex:1; height:6px; border-radius:4px; background:{{ gb3 }};\"><\u002Fdiv>\n      <\u002Fdiv>\n      <div style=\"padding:24px 28px 30px;\">\n        <div style=\"font-family:'Space Mono',monospace; font-size:12px; font-weight:700; color:#a59986;\">STEP {{ gStepLabel }} OF 4<\u002Fdiv>\n        <div style=\"font-family:'Unbounded',sans-serif; font-size:24px; font-weight:600; margin-top:10px; line-height:1.15; letter-spacing:-.01em;\">{{ gQuestion }}<\u002Fdiv>\n        <div style=\"font-size:15px; color:#7A6F60; margin-top:10px; line-height:1.5;\">{{ gHelp }}<\u002Fdiv>\n        <div style=\"margin-top:24px; display:flex; gap:12px; align-items:center;\">\n          <div onclick=\"{{ guideBack }}\" style=\"padding:12px 20px; border-radius:30px; border:1px solid #ece0cc; font-weight:700; font-size:14px; cursor:pointer; background:#fff; color:#7A6F60;\">Back<\u002Fdiv>\n          <div onclick=\"{{ guideNext }}\" style=\"flex:1; text-align:center; padding:12px 20px; border-radius:30px; background:#E2701A; color:#fff; font-weight:700; font-size:14px; cursor:pointer;\">{{ gNextLabel }}<\u002Fdiv>\n        <\u002Fdiv>\n      <\u002Fdiv>\n    <\u002Fdiv>\n  <\u002Fdiv>\n  <\u002Fsc-if>\n\n<\u002Fdiv>\n\n<\u002Fx-dc>\n<script type=\"text/x-dc\" data-dc-script=\"\">\nclass Component extends DCLogic {\n  state = { view: 'home', topic: 'coi', guideOpen: false, gStep: 0 };\n\n  topics = {\n    code: {\n      num: '01', color: '#efe9e0', icon: '\\u2696\\uFE0F', title: 'Code of Conduct',\n      summary: 'It\\u2019s the short list of promises we make to each other, our drinkers, and the communities we sell in. When in doubt, this is the floor \\u2014 never the ceiling.',\n      q1: 'Would I be fine if my manager saw exactly what I\\u2019m about to do?',\n      q2: 'Does this hold up to what we tell our customers about Brindle?',\n      q3: 'Am I treating the people around me the way I\\u2019d want to be treated?',\n      ok: 'Calling out a teammate\\u2019s great work in a company-wide channel \\u2014 genuine recognition, no strings.',\n      pause: 'A vendor offers to \\u201Ctake care of\\u201D a personal expense as a thank-you. Friendly, but log it and check before accepting.',\n      no: 'Fudging a shipment date in the system so a quarterly number looks better. That\\u2019s never a gray area.'\n    },\n    coi: {\n      num: '02', color: '#fbe3d1', icon: '\\uD83E\\uDD1D', title: 'Conflicts of Interest',\n      summary: 'A conflict is just when your personal life could \\u2014 even by accident \\u2014 pull you away from doing what\\u2019s best for Brindle. Having one isn\\u2019t the problem. Hiding it is.',\n      q1: 'Could someone reasonably think my personal stake swayed this decision?',\n      q2: 'Am I on both sides of this \\u2014 deciding and benefiting?',\n      q3: 'Would I be comfortable if this showed up in the company newsletter?',\n      ok: 'Your partner works at an unrelated company we\\u2019ll never do business with. Nothing to disclose \\u2014 carry on.',\n      pause: 'You\\u2019re picking a new agency and your college roommate pitches one of them. Disclose it and step back from the vote.',\n      no: 'You approve a contract for a company you secretly co-own. Self-dealing, full stop.'\n    },\n    privacy: {\n      num: '03', color: '#ece7f7', icon: '\\uD83D\\uDD12', title: 'Data Privacy',\n      summary: 'Every email, loyalty signup, and survey is a person trusting us with their info. We collect only what we need, use it only for what we said, and guard it like it\\u2019s our own.',\n      q1: 'Did this person actually agree to us using their data this way?',\n      q2: 'Am I only touching the data I genuinely need for this task?',\n      q3: 'If this data leaked tomorrow, would I be able to explain my choices?',\n      ok: 'Pulling aggregate, anonymized sales trends for a deck. No individuals, no problem.',\n      pause: 'Exporting a customer list to a personal drive to \\u201Cwork from home.\\u201D Stop \\u2014 use approved tools and ask first.',\n      no: 'Looking up a friend\\u2019s order history out of curiosity. Access is for the job, not for fun.'\n    }\n  };\n\n  guide = [\n    { q: 'Who could be affected by this decision?', help: 'Name them out loud \\u2014 teammates, customers, the company, you. If you\\u2019re one of the people who benefits, slow down.' },\n    { q: 'Would you be comfortable if it were public?', help: 'Picture it in a headline or a group chat. If that makes you wince, it\\u2019s worth a second look.' },\n    { q: 'Does it line up with our Code and your gut?', help: 'Policies set the floor. Your instinct usually knows before the rulebook does.' },\n    { q: 'Still unsure? Then ask before you act.', help: 'A 5-minute question beats a 5-month cleanup. We\\u2019re here, judgment-free.' }\n  ];\n\n  renderVals() {\n    const v = this.state.view;\n    const t = this.topics[this.state.topic] || this.topics.coi;\n    const g = this.guide[this.state.gStep] || this.guide[0];\n    const bar = (i) => i <= this.state.gStep ? '#E2701A' : '#e7d8bf';\n    const last = this.state.gStep === this.guide.length - 1;\n    const open = (id) => () => { this.setState({ view: 'policy', topic: id }); window.scrollTo(0,0); };\n    return {\n      isHome: v === 'home',\n      isPolicy: v === 'policy',\n      isSpeakUp: v === 'speakup',\n      goHome: () => { this.setState({ view: 'home', guideOpen: false }); window.scrollTo(0,0); },\n      openCode: open('code'),\n      openCOI: open('coi'),\n      openPrivacy: open('privacy'),\n      openTraining: () => { window.location.href = 'Training Module.dc.html'; },\n      openResources: () => { window.location.href = 'Animated Explainer.dc.html'; },\n      openSpeakUp: () => { this.setState({ view: 'speakup', guideOpen: false }); window.scrollTo(0,0); },\n      openGuide: () => this.setState({ guideOpen: true, gStep: 0 }),\n      closeGuide: () => this.setState({ guideOpen: false }),\n      guideOpen: this.state.guideOpen,\n      guideNext: () => last ? this.setState({ guideOpen: false }) : this.setState(s => ({ gStep: s.gStep + 1 })),\n      guideBack: () => this.setState(s => ({ gStep: Math.max(0, s.gStep - 1) })),\n      gStep: this.state.gStep,\n      gStepLabel: this.state.gStep + 1,\n      gQuestion: g.q,\n      gHelp: g.help,\n      gNextLabel: last ? 'Got it \\u2713' : 'Next \\u2192',\n      gb0: bar(0), gb1: bar(1), gb2: bar(2), gb3: bar(3),\n      pNum: t.num, pColor: t.color, pIcon: t.icon, pTitle: t.title, pSummary: t.summary,\n      pQ1: t.q1, pQ2: t.q2, pQ3: t.q3, p